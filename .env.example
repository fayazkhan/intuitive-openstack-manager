# Environment variables for local development

# Choose backend: 'mock' (default) or 'openstack'
OPENSTACK_BACKEND=mock

# When using a real OpenStack backend, set the following:
# OPENSTACK_AUTH_URL=
# OPENSTACK_PROJECT_NAME=
# OPENSTACK_USERNAME=
# OPENSTACK_PASSWORD=
# OPENSTACK_USER_DOMAIN_NAME=Default
# OPENSTACK_PROJECT_DOMAIN_NAME=Default
